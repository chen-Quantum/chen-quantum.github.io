---
import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/CourseCard.astro";
import { getCollection } from "astro:content";

const allCourses = await getCollection("courses", ({ data }) => !data.draft);
allCourses.sort((a, b) => b.data.semester.localeCompare(a.data.semester));

const featured = allCourses.filter((c) => c.data.featured);
const others = allCourses.filter((c) => !c.data.featured);

const totalVideos = allCourses.reduce(
  (sum, c) => sum + c.data.youtubeLinks.length,
  0
);
const totalTutorials = allCourses.reduce(
  (sum, c) => sum + c.data.tutorials.length,
  0
);
---

<Layout
  title="Courses"
  description="Course materials, lecture recordings, tutorials, and assignments — Chen Quantum."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Teaching
      </p>
      <h1
        class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5"
      >
        Courses
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed mb-8">
        Lecture recordings, tutorials, practice problems, and assignments for
        courses I teach and assist with.
      </p>

      <!-- Stats row -->
      {
        allCourses.length > 0 && (
          <dl class="flex flex-wrap gap-6">
            <div class="flex items-baseline gap-1.5">
              <dd class="text-sm font-semibold text-slate-900 tabular-nums">
                {allCourses.length}
              </dd>
              <dt class="text-xs text-slate-400">courses</dt>
            </div>
            <div class="flex items-baseline gap-1.5">
              <dd class="text-sm font-semibold text-slate-900 tabular-nums">
                {totalVideos}
              </dd>
              <dt class="text-xs text-slate-400">recordings</dt>
            </div>
            <div class="flex items-baseline gap-1.5">
              <dd class="text-sm font-semibold text-slate-900 tabular-nums">
                {totalTutorials}
              </dd>
              <dt class="text-xs text-slate-400">practice sheets</dt>
            </div>
          </dl>
        )
      }
    </div>
  </section>

  <!-- Course grid -->
  <div class="mx-auto max-w-6xl px-6 py-16">
    {
      allCourses.length === 0 ? (
        <div class="py-24 text-center">
          <p class="text-3xl font-display text-slate-300 mb-4">No courses yet</p>
          <p class="text-sm text-slate-400">Course materials will appear here soon.</p>
        </div>
      ) : (
        <div class="space-y-14">
          {featured.length > 0 && (
            <div>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
                Featured
              </p>
              <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {featured.map((course) => (
                  <CourseCard
                    title={course.data.title}
                    shortDescription={course.data.shortDescription}
                    semester={course.data.semester}
                    tags={course.data.tags}
                    slug={course.id}
                    featured={true}
                  />
                ))}
              </div>
            </div>
          )}

          {others.length > 0 && (
            <div>
              {featured.length > 0 && (
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
                  All Courses
                </p>
              )}
              <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {others.map((course) => (
                  <CourseCard
                    title={course.data.title}
                    shortDescription={course.data.shortDescription}
                    semester={course.data.semester}
                    tags={course.data.tags}
                    slug={course.id}
                  />
                ))}
              </div>
            </div>
          )}
        </div>
      )
    }
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const items = await getCollection("library", ({ data }) => !data.draft);
items.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const kindLabels: Record<string, string> = {
  recording: "Recording",
  practice: "Practice",
  tip: "Tip",
  "short-video": "Video",
  "study-song": "Study Song",
};

const kindColors: Record<string, string> = {
  recording: "text-violet-700 bg-violet-50",
  practice: "text-emerald-700 bg-emerald-50",
  tip: "text-amber-700 bg-amber-50",
  "short-video": "text-sky-700 bg-sky-50",
  "study-song": "text-rose-700 bg-rose-50",
};
---

<Layout
  title="Library"
  description="Recordings, tips, and practice material — Chen Gadi."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Resources
      </p>
      <h1
        class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5"
      >
        Library
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed">
        Recordings, practice problems, tips, and study material from
        tutorials and office hours.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-16">
    {
      items.length === 0 ? (
        <div class="py-24 max-w-sm">
          <p class="font-display text-3xl text-slate-200 mb-4">
            Being built.
          </p>
          <p class="text-sm text-slate-400 leading-relaxed">
            Library content will appear here as it is added.
          </p>
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {items.map((item) => (
            <div class="group flex flex-col p-5 bg-white rounded-xl border border-slate-200 hover:border-slate-300 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200 ease-out">
              <!-- Kind + date -->
              <div class="flex items-center justify-between mb-4">
                <span
                  class={`text-[0.65rem] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full ${kindColors[item.data.kind] ?? "text-slate-600 bg-slate-100"}`}
                >
                  {kindLabels[item.data.kind] ?? item.data.kind}
                </span>
                <span class="text-[0.65rem] font-medium text-slate-400 tabular-nums">
                  {item.data.date.toLocaleDateString("en-US", {
                    month: "short",
                    year: "numeric",
                  })}
                </span>
              </div>

              <!-- Title -->
              <h3 class="text-sm font-semibold text-slate-900 mb-2 leading-snug group-hover:text-indigo-600 transition-colors">
                {item.data.title}
              </h3>

              <!-- Description -->
              <p class="text-xs text-slate-500 leading-relaxed flex-1 mb-4">
                {item.data.description}
              </p>

              <!-- Course label -->
              {item.data.course && (
                <p class="text-[0.65rem] font-medium text-slate-400 uppercase tracking-wide mb-3">
                  {item.data.course}
                </p>
              )}

              <!-- Tags -->
              {item.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {item.data.tags.map((tag) => (
                    <span class="text-[0.65rem] font-medium text-slate-500 bg-slate-50 border border-slate-200 px-1.5 py-0.5 rounded uppercase tracking-wide">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <!-- Link -->
              {item.data.embedUrl && (
                <a
                  href={item.data.embedUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-auto inline-flex items-center gap-1 text-xs font-semibold text-slate-700 hover:text-indigo-600 transition-colors"
                >
                  Open resource ↗
                </a>
              )}
            </div>
          ))}
        </div>
      )
    }
  </div>
</Layout>

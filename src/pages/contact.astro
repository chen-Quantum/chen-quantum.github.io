---
import Layout from "../layouts/Layout.astro";

const EMAIL = "chengadi@mail.tau.ac.il";
const WHATSAPP_NUMBER = "972525501669"; // international format, no + sign
const WHATSAPP_LABEL = "052-550-1669";
---

<Layout
  title="Contact"
  description="Contact Chen Gadi — private lessons, academic collaboration, and general inquiries."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Get in Touch
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5">
        Contact
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed">
        For tutoring, teaching materials, quantum community events, research
        collaborations, and project inquiries — reach out by email or WhatsApp.
      </p>

      <!-- Quick contact buttons -->
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={`mailto:${EMAIL}`}
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
        >
          Email
          <span class="text-xs font-normal opacity-80 hidden sm:inline">{EMAIL}</span>
        </a>
        <a
          href={`https://wa.me/${WHATSAPP_NUMBER}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-600 text-white text-sm font-semibold rounded-lg hover:bg-emerald-700 transition-colors"
        >
          Message on WhatsApp
          <span class="text-xs font-normal opacity-80 hidden sm:inline">{WHATSAPP_LABEL}</span>
        </a>
        <a
          href="/files/cv/chen-gadi-cv-2026.pdf"
          download
          class="inline-flex items-center gap-2 px-5 py-2.5 text-slate-700 text-sm font-semibold rounded-lg border border-slate-200 hover:border-slate-300 hover:text-slate-900 transition-colors"
        >
          Download CV
        </a>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-16 items-start">

      <!-- Left: content -->
      <div>
        <!-- Private lessons section -->
        <section class="mb-14">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
            Private Lessons
          </p>
          <div class="p-8 rounded-2xl bg-gradient-to-br from-indigo-50 to-slate-50 border border-indigo-100 mb-8">
            <h2 class="font-display text-2xl md:text-3xl text-slate-900 mb-4 leading-snug">
              One-on-one tutoring in mathematics and quantum computing.
            </h2>
            <p class="text-slate-600 leading-relaxed mb-6">
              I offer private lessons for students at all levels — from
              introductory courses to graduate-level material. Sessions are
              tailored to your specific needs, pace, and goals.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
              {[
                {
                  subject: "Linear Algebra",
                  note: "From foundations to spectral theory",
                },
                {
                  subject: "Quantum Computing",
                  note: "Theory, algorithms, and Qiskit",
                },
                {
                  subject: "Multivariable Calculus",
                  note: "Partial derivatives, vector calculus",
                },
                {
                  subject: "Discrete Mathematics",
                  note: "Logic, combinatorics, graph theory",
                },
              ].map(({ subject, note }) => (
                <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-slate-200">
                  <div class="flex-shrink-0 w-2 h-2 rounded-full bg-indigo-400 mt-1.5"></div>
                  <div>
                    <p class="text-sm font-semibold text-slate-800">{subject}</p>
                    <p class="text-xs text-slate-500">{note}</p>
                  </div>
                </div>
              ))}
            </div>

            <a
              href={`mailto:${EMAIL}?subject=Private Lessons Inquiry`}
              class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 transition-colors"
            >
              Send an enquiry
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </section>

        <div class="border-t border-slate-100 mb-14"></div>

        <!-- Private courses section -->
        <section class="mb-14">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
            Private / Group Courses
          </p>
          <p class="text-base text-slate-600 leading-relaxed mb-6 max-w-2xl">
            Interested in a structured course for a small group — your lab,
            study group, or company team? I can design a custom curriculum and
            deliver it over several sessions. Topics include quantum computing
            fundamentals, linear algebra, and mathematical methods for CS.
          </p>
          <a
            href={`mailto:${EMAIL}?subject=Private Course Inquiry`}
            class="inline-flex items-center gap-2 text-sm font-semibold text-slate-700 border border-slate-200 hover:border-slate-300 hover:text-slate-900 px-5 py-2.5 rounded-xl transition-colors"
          >
            Inquire about group courses
          </a>
        </section>

        <div class="border-t border-slate-100 mb-14"></div>

        <!-- General contact -->
        <section>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
            General Inquiries
          </p>
          <p class="text-base text-slate-600 leading-relaxed mb-8 max-w-2xl">
            For academic collaboration, speaking invitations, quantum community
            partnership, or anything else — email is the best way to reach me.
          </p>

          <div class="space-y-3">
            <!-- Email -->
            <a
              href={`mailto:${EMAIL}`}
              class="group flex items-center gap-4 p-4 rounded-xl border border-slate-200 hover:border-indigo-200 hover:bg-indigo-50/20 transition-all"
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-slate-100 group-hover:bg-indigo-100 flex items-center justify-center transition-colors">
                <svg class="h-5 w-5 text-slate-500 group-hover:text-indigo-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors">Email</p>
                <p class="text-xs text-slate-400">{EMAIL}</p>
              </div>
            </a>

            <!-- WhatsApp -->
            <a
              href={`https://wa.me/${WHATSAPP_NUMBER}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 p-4 rounded-xl border border-slate-200 hover:border-emerald-200 hover:bg-emerald-50/20 transition-all"
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-slate-100 group-hover:bg-emerald-100 flex items-center justify-center transition-colors">
                <svg class="h-5 w-5 text-slate-500 group-hover:text-emerald-600 transition-colors" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-800 group-hover:text-emerald-600 transition-colors">WhatsApp</p>
                <p class="text-xs text-slate-400">{WHATSAPP_LABEL}</p>
              </div>
            </a>
          </div>
        </section>
      </div>

      <!-- Right: sidebar -->
      <aside class="lg:sticky lg:top-20 space-y-4">
        <!-- Availability card -->
        <div class="rounded-xl border border-slate-100 bg-white p-5">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
            Current Availability
          </p>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-emerald-500 flex-shrink-0"></span>
            <p class="text-sm font-medium text-slate-800">Available for private lessons</p>
          </div>
          <p class="text-xs text-slate-500 leading-relaxed">
            I currently have limited spots for private tutoring. Enquire early
            to reserve a slot.
          </p>
        </div>

        <!-- What to include card -->
        <div class="rounded-xl border border-slate-100 bg-slate-50 p-5">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
            When You Write
          </p>
          <ul class="space-y-2.5">
            {[
              "Which course or topic you need help with",
              "Your current level and background",
              "Preferred frequency (weekly, bi-weekly, etc.)",
              "Any upcoming deadlines or exam dates",
            ].map((item) => (
              <li class="flex items-start gap-2 text-xs text-slate-600">
                <span class="flex-shrink-0 w-1.5 h-1.5 rounded-full bg-indigo-300 mt-1.5"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- CV link -->
        <div class="rounded-xl border border-slate-100 bg-white p-5">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">
            Academic Profile
          </p>
          <a
            href="/cv"
            class="flex items-center justify-between text-sm font-medium text-slate-700 hover:text-indigo-600 transition-colors"
          >
            View my CV
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </aside>
    </div>
  </div>
</Layout>

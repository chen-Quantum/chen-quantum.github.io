---
import Layout from "../layouts/Layout.astro";
import LiteYouTube from "../components/LiteYouTube.astro";
import PdfPreview from "../components/PdfPreview.astro";
import { getCollection } from "astro:content";
import { tirgulim } from "../data/tirgulim";
import { teachingCourses } from "../data/courses";
import {
  youtubeVideos,
  hedva2Videos,
  linearAlgebraVideos,
  unknownVideos,
  videosForPractice,
} from "../data/youtubeVideos";

const allTeaching = await getCollection("teaching", ({ data }) => !data.draft);
const activeCourses = allTeaching
  .filter((c) => c.data.status === "active")
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

function countFor(courseId: string) {
  if (courseId === "calculus-2")
    return { materials: tirgulim.length, videos: hedva2Videos.length };
  if (courseId === "linear-algebra-electrical")
    return {
      materials: 0,
      videos: linearAlgebraVideos.filter((v) => v.track.includes("Electrical")).length,
    };
  if (courseId === "linear-algebra-biomedical")
    return {
      materials: 0,
      videos: linearAlgebraVideos.filter((v) => v.track.includes("Biomedical")).length,
    };
  return { materials: 0, videos: 0 };
}

// Linear Algebra recordings grouped by tutorial number (newest first) + exam question.
const laTutorialNumbers = [13, 12, 11, 10, 9, 8];
const laGroups = laTutorialNumbers
  .map((n) => ({ n, videos: linearAlgebraVideos.filter((v) => v.laTutorial === n) }))
  .filter((g) => g.videos.length > 0);
const laExam = linearAlgebraVideos.filter((v) => v.isExamQuestion);

// Course filters: render a chip only for courses that actually have content
// (videos or practice sheets). Future courses in the registry stay hidden until
// material is classified into them.
const filterCourses = teachingCourses.filter(
  (c) =>
    youtubeVideos.some((v) => v.courseId === c.id) ||
    tirgulim.some((t) => t.courseId === c.id)
);
---

<Layout
  title="Teaching"
  description="Teaching by Chen Gadi at Tel Aviv University — linear algebra and calculus 2 (Hedva 2) for engineering students. Practice sheets and tutorial recordings."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Teaching
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5">
        Teaching at Tel Aviv University
      </h1>
      <p class="text-base text-slate-500 max-w-2xl leading-relaxed">
        Teaching-assistant work in mathematics for engineering students: linear
        algebra (electrical and biomedical engineering tracks) and calculus 2
        (Hedva 2). Below are the practice sheets and full tutorial recordings.
      </p>
      <p class="mt-4 text-xs text-slate-400 max-w-2xl leading-relaxed">
        Recordings are <strong class="font-semibold text-slate-500">unlisted YouTube videos</strong>,
        available through this page and the course links. Unlisted videos are not
        private — anyone with a link can view them.
      </p>
    </div>
  </section>

  <!-- Current courses -->
  <div class="mx-auto max-w-6xl px-6 py-14 md:py-16">
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
      Current Courses
    </p>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {activeCourses.map((c) => {
        const { materials, videos } = countFor(c.data.courseId);
        return (
          <div class="flex flex-col p-6 bg-white rounded-2xl border border-slate-200 hover:border-slate-300 hover:shadow-sm transition-all">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full text-emerald-700 bg-emerald-50 border border-emerald-200">
                {c.data.semester}
              </span>
              {c.data.titleHebrew && (
                <span class="text-xs text-slate-400" dir="rtl">{c.data.titleHebrew}</span>
              )}
            </div>
            <h3 class="text-base font-semibold text-slate-900 mb-2 leading-snug">
              {c.data.title}
            </h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-4 flex-1">
              {c.data.description}
            </p>
            {c.data.audience.length > 0 && (
              <div class="mb-4">
                <p class="text-[0.65rem] font-semibold text-slate-400 uppercase tracking-wide mb-1.5">Audience</p>
                <div class="flex flex-wrap gap-1.5">
                  {c.data.audience.map((a) => (
                    <span class="text-[0.65rem] font-medium text-slate-600 bg-slate-100 px-2 py-0.5 rounded-full">{a}</span>
                  ))}
                </div>
              </div>
            )}
            <div class="mt-auto pt-3 border-t border-slate-100 flex items-center gap-4 text-xs text-slate-400">
              <span>{materials} practice sheet{materials === 1 ? "" : "s"}</span>
              <span>·</span>
              <span>{videos} recording{videos === 1 ? "" : "s"}</span>
            </div>
          </div>
        );
      })}
    </div>

    <!-- ─── Course filter ───────────────────────────────────────── -->
    {filterCourses.length > 1 && (
      <div class="mt-16 md:mt-20" data-course-filter>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
          Browse by course
        </p>
        <div class="flex flex-wrap gap-2">
          <button
            type="button"
            data-course="all"
            class="text-sm font-semibold px-4 py-2 rounded-full border bg-slate-900 text-white border-slate-900 transition-colors"
          >
            All
          </button>
          {filterCourses.map((c) => (
            <button
              type="button"
              data-course={c.id}
              class="text-sm font-semibold px-4 py-2 rounded-full border bg-white text-slate-600 border-slate-200 hover:border-slate-300 transition-colors"
            >
              {c.tag}
            </button>
          ))}
        </div>
      </div>
    )}

    <!-- ─── Hedva 2 ─────────────────────────────────────────────── -->
    <section class="mt-10 md:mt-12 scroll-mt-24" id="hedva-2" data-course-section="hedva2">
      <div class="flex items-baseline justify-between flex-wrap gap-2 mb-2">
        <h2 class="font-display text-2xl md:text-3xl text-slate-900">
          Calculus 2 · Hedva 2 — practice sessions
        </h2>
        <span class="text-sm text-slate-400" dir="rtl">חדו״א 2 — תרגולים</span>
      </div>
      <p class="text-sm text-slate-500 leading-relaxed max-w-3xl mb-8">
        Five practice sessions covering sequences and series of functions, power
        series, multivariable foundations, and differentiability. Each session has
        a practice sheet (PDF) and full recordings across the engineering tracks.
      </p>

      <div class="space-y-6">
        {tirgulim.map((t) => {
          const vids = videosForPractice(t.id);
          return (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-8">
              <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
                <div>
                  <p class="text-base font-semibold text-slate-900">{t.titleEn}</p>
                  <p class="text-sm text-slate-500 mt-1" dir="rtl">{t.titleHe}</p>
                </div>
                <a
                  href={t.pdfPath}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-indigo-700 bg-indigo-50 border border-indigo-100 rounded-lg hover:bg-indigo-100 transition-colors flex-shrink-0"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  Practice sheet (PDF)
                </a>
              </div>

              <div class="flex flex-wrap gap-1.5 mb-4" dir="rtl">
                {t.topics.map((tp) => (
                  <span class="text-[0.7rem] font-medium text-slate-600 bg-slate-100 px-2.5 py-1 rounded-full">{tp}</span>
                ))}
              </div>

              <div class="mb-6">
                <PdfPreview pdfPath={t.pdfPath} title={t.titleEn} />
              </div>

              {vids.length > 0 && (
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  {vids.map((v) => (
                    <LiteYouTube
                      videoId={v.videoId}
                      title={v.title}
                      thumbnail={v.thumbnail}
                      embedUrl={v.embedUrl}
                      url={v.url}
                      duration={v.duration}
                      track={v.track}
                    />
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <!-- ─── Linear Algebra ──────────────────────────────────────── -->
    <section class="mt-16 md:mt-20 scroll-mt-24" id="linear-algebra" data-course-section="linear-algebra">
      <div class="flex items-baseline justify-between flex-wrap gap-2 mb-2">
        <h2 class="font-display text-2xl md:text-3xl text-slate-900">
          Linear Algebra — tutorial recordings
        </h2>
        <span class="text-sm text-slate-400" dir="rtl">לינארית — תרגולים</span>
      </div>
      <p class="text-sm text-slate-500 leading-relaxed max-w-3xl mb-8">
        Full tutorial recordings across the electrical and biomedical engineering
        tracks (tutorials 8–13), plus a worked exam question. Written materials are
        being organized and will be added here.
      </p>

      <div class="space-y-10">
        {laGroups.map((g) => (
          <div>
            <p class="text-sm font-semibold text-slate-900 mb-4">Tutorial {g.n}</p>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {g.videos.map((v) => (
                <LiteYouTube
                  videoId={v.videoId}
                  title={v.title}
                  thumbnail={v.thumbnail}
                  embedUrl={v.embedUrl}
                  url={v.url}
                  duration={v.duration}
                  track={v.track}
                  note={v.sessionNote}
                />
              ))}
            </div>
          </div>
        ))}

        {laExam.length > 0 && (
          <div>
            <p class="text-sm font-semibold text-slate-900 mb-4">Worked exam question (2022)</p>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {laExam.map((v) => (
                <LiteYouTube
                  videoId={v.videoId}
                  title={v.title}
                  thumbnail={v.thumbnail}
                  embedUrl={v.embedUrl}
                  url={v.url}
                  duration={v.duration}
                  track={v.track}
                />
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- ─── Needs classification (admin-only; renders only if non-empty) ─── -->
    {unknownVideos.length > 0 && (
      <section class="mt-16 md:mt-20" data-course-section="unknown">
        <div class="rounded-2xl border border-dashed border-amber-300 bg-amber-50/40 p-6">
          <p class="text-xs font-semibold text-amber-700 uppercase tracking-widest mb-2">
            Needs classification
          </p>
          <p class="text-sm text-slate-600 leading-relaxed max-w-3xl mb-4">
            {unknownVideos.length} playlist recording{unknownVideos.length === 1 ? "" : "s"} could
            not be confidently matched to a course from the title alone. Listed here for
            manual review — not shown anywhere else on the site.
          </p>
          <ul class="space-y-1.5">
            {unknownVideos.map((v) => (
              <li class="text-sm" dir="rtl">
                <a href={v.url} target="_blank" rel="noopener noreferrer" class="text-slate-600 hover:text-indigo-700">{v.title}</a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Get in touch -->
    <section class="mt-16 md:mt-20">
      <div class="rounded-2xl border border-indigo-100 bg-indigo-50/40 p-8 max-w-3xl">
        <h2 class="font-display text-xl md:text-2xl text-slate-900 mb-2">
          Looking for tutoring or specific materials?
        </h2>
        <p class="text-sm text-slate-600 leading-relaxed mb-5">
          I run tutorials and private lessons in linear algebra and calculus (1 &amp; 2)
          for engineering students. If you are a current student and need a specific
          sheet or recording, get in touch.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
        >
          Contact page →
        </a>
      </div>
    </section>
  </div>

  {/* Video classification note (developer-facing): all 30 playlist videos are
     classified — 13 Hedva 2, 17 Linear Algebra, 0 unknown. The "Needs
     classification" section above renders only when unknownVideos is non-empty.
     Course tags/filters are driven by src/data/courses.ts (courseFor). */}

  <script>
    // Course filter: show only the section(s) for the selected course.
    // Vanilla JS, no framework — mirrors the LiteYouTube delegated pattern.
    (() => {
      const bar = document.querySelector("[data-course-filter]");
      if (!bar) return;
      const buttons = Array.from(
        bar.querySelectorAll("button[data-course]")
      ) as HTMLButtonElement[];
      const sections = Array.from(
        document.querySelectorAll("[data-course-section]")
      ) as HTMLElement[];
      const ON = ["bg-slate-900", "text-white", "border-slate-900"];
      const OFF = ["bg-white", "text-slate-600", "border-slate-200", "hover:border-slate-300"];

      function apply(course: string) {
        sections.forEach((s) => {
          const show = course === "all" || s.dataset.courseSection === course;
          s.classList.toggle("hidden", !show);
        });
        buttons.forEach((b) => {
          const on = (b.dataset.course || "") === course;
          ON.forEach((c) => b.classList.toggle(c, on));
          OFF.forEach((c) => b.classList.toggle(c, !on));
        });
      }

      bar.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(
          "button[data-course]"
        ) as HTMLButtonElement | null;
        if (!btn) return;
        apply(btn.dataset.course || "all");
      });
    })();
  </script>
</Layout>

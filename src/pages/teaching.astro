---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { teachingMaterials } from "../data/teachingMaterials";
import { teachingVideos } from "../data/teachingVideos";

const allTeaching = await getCollection("teaching", ({ data }) => !data.draft);
const activeCourses = allTeaching
  .filter((c) => c.data.status === "active")
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

function countFor(courseId: string) {
  return {
    materials: teachingMaterials.filter((m) => m.courseId === courseId).length,
    videos: teachingVideos.filter((v) => v.courseId === courseId).length,
  };
}
---

<Layout
  title="Teaching"
  description="Teaching by Chen Gadi at Tel Aviv University — linear algebra and calculus 2 for engineering students. Materials and lecture videos are being organized and uploaded gradually."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Teaching
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5">
        Teaching at Tel Aviv University
      </h1>
      <p class="text-base text-slate-500 max-w-2xl leading-relaxed">
        Current teaching assistant work in mathematics for engineering students:
        linear algebra (electrical and biomedical engineering tracks) and
        calculus 2. Lecture notes, worksheets, and recordings are being
        gradually organized and uploaded.
      </p>
    </div>
  </section>

  <!-- Courses -->
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
      Current Courses
    </p>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {activeCourses.map((c) => {
        const { materials, videos } = countFor(c.data.courseId);
        return (
          <div class="flex flex-col p-6 bg-white rounded-2xl border border-slate-200 hover:border-slate-300 hover:shadow-sm transition-all">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full text-emerald-700 bg-emerald-50 border border-emerald-200">
                {c.data.semester}
              </span>
              {c.data.titleHebrew && (
                <span class="text-xs text-slate-400" dir="rtl">{c.data.titleHebrew}</span>
              )}
            </div>
            <h3 class="text-base font-semibold text-slate-900 mb-2 leading-snug">
              {c.data.title}
            </h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-4 flex-1">
              {c.data.description}
            </p>

            {c.data.audience.length > 0 && (
              <div class="mb-4">
                <p class="text-[0.65rem] font-semibold text-slate-400 uppercase tracking-wide mb-1.5">
                  Audience
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {c.data.audience.map((a) => (
                    <span class="text-[0.65rem] font-medium text-slate-600 bg-slate-100 px-2 py-0.5 rounded-full">{a}</span>
                  ))}
                </div>
              </div>
            )}

            {c.data.topics.length > 0 && (
              <div class="mb-4">
                <p class="text-[0.65rem] font-semibold text-slate-400 uppercase tracking-wide mb-1.5">
                  Topics
                </p>
                <ul class="text-xs text-slate-500 leading-relaxed space-y-0.5 columns-1 sm:columns-2">
                  {c.data.topics.slice(0, 8).map((t) => (
                    <li>· {t}</li>
                  ))}
                  {c.data.topics.length > 8 && (
                    <li class="text-slate-400">… and more</li>
                  )}
                </ul>
              </div>
            )}

            <div class="mt-auto pt-3 border-t border-slate-100 flex items-center gap-4 text-xs text-slate-400">
              <span>{materials} material{materials === 1 ? "" : "s"}</span>
              <span>·</span>
              <span>{videos} video{videos === 1 ? "" : "s"}</span>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Materials section -->
    <section class="mt-16 md:mt-20">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
        Materials
      </p>
      <div class="rounded-2xl border border-slate-100 bg-slate-50/50 p-8">
        <p class="text-base text-slate-600 leading-relaxed max-w-3xl mb-4">
          Lecture notes, practice worksheets, and reference sheets are being
          gradually organized and uploaded. Items marked
          <span class="text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded text-xs font-semibold border border-amber-200">coming soon</span>
          are planned; items that are already prepared appear as direct download links.
        </p>
        <p class="text-sm text-slate-500 leading-relaxed max-w-3xl">
          Materials are gradually being organized and uploaded. If you are a
          current student and need something urgently, please get in touch via
          the <a href="/contact" class="text-indigo-600 hover:underline">contact page</a>.
        </p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {activeCourses.map((c) => {
          const courseMaterials = teachingMaterials.filter((m) => m.courseId === c.data.courseId);
          if (courseMaterials.length === 0) return null;
          return (
            <div class="p-5 rounded-xl border border-slate-200 bg-white">
              <p class="text-sm font-semibold text-slate-900 mb-3">{c.data.title}</p>
              <ul class="space-y-2">
                {courseMaterials.map((m) => (
                  <li class="flex items-start gap-2 text-xs">
                    <span class={`flex-shrink-0 w-1.5 h-1.5 rounded-full mt-1.5 ${m.status === "available" ? "bg-emerald-400" : "bg-slate-300"}`}></span>
                    {m.status === "available" ? (
                      <a href={m.href} class="text-slate-700 hover:text-indigo-600 transition-colors">{m.title}</a>
                    ) : (
                      <span class="text-slate-500">
                        {m.title}
                        <span class="ml-2 text-[0.6rem] font-semibold uppercase tracking-wider text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded border border-amber-200">coming soon</span>
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Videos section -->
    <section class="mt-16 md:mt-20">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
        Lecture videos
      </p>
      <p class="text-sm text-slate-500 leading-relaxed max-w-3xl mb-6">
        Short explanatory videos for the trickiest topics in each course.
        Videos are hosted externally — the embed list below will be filled in
        as recordings are published.
      </p>
      <div class="grid gap-4 md:grid-cols-2">
        {activeCourses.map((c) => {
          const courseVideos = teachingVideos.filter((v) => v.courseId === c.data.courseId);
          if (courseVideos.length === 0) return null;
          return (
            <div class="p-5 rounded-xl border border-slate-200 bg-white">
              <p class="text-sm font-semibold text-slate-900 mb-3">{c.data.title}</p>
              <ul class="space-y-2">
                {courseVideos.map((v) => (
                  <li class="flex items-start gap-2 text-xs">
                    <span class={`flex-shrink-0 w-1.5 h-1.5 rounded-full mt-1.5 ${v.status === "available" ? "bg-emerald-400" : "bg-slate-300"}`}></span>
                    {v.status === "available" && v.url ? (
                      <a href={v.url} target="_blank" rel="noopener noreferrer" class="text-slate-700 hover:text-indigo-600 transition-colors">{v.title}</a>
                    ) : (
                      <span class="text-slate-500">
                        {v.title}
                        <span class="ml-2 text-[0.6rem] font-semibold uppercase tracking-wider text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded border border-amber-200">coming soon</span>
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Get in touch -->
    <section class="mt-16 md:mt-20">
      <div class="rounded-2xl border border-indigo-100 bg-indigo-50/40 p-8 max-w-3xl">
        <h2 class="font-display text-xl md:text-2xl text-slate-900 mb-2">
          Looking for tutoring or specific materials?
        </h2>
        <p class="text-sm text-slate-600 leading-relaxed mb-5">
          I run private tutoring sessions for linear algebra, calculus 2, and
          introductory quantum computing for engineering and physics students.
          Get in touch by email or WhatsApp.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
        >
          Contact page →
        </a>
      </div>
    </section>
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import CourseCard from "../components/CourseCard.astro";
import MaterialCard from "../components/MaterialCard.astro";
import { getCollection } from "astro:content";

const allCourses = await getCollection("courses", ({ data }) => !data.draft);
const featuredCourses = allCourses.filter((c) => c.data.featured);
featuredCourses.sort((a, b) => b.data.semester.localeCompare(a.data.semester));

const allMaterials = await getCollection("materials", ({ data }) => !data.draft);
const featuredMaterials = allMaterials.filter((m) => m.data.featured);
featuredMaterials.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allEvents = await getCollection("communityEvents", ({ data }) => !data.draft);
const upcomingEvents = allEvents.filter((e) => e.data.status === "upcoming");
const featuredEvents = allEvents.filter((e) => e.data.featured).slice(0, 2);

const totalVideos = allCourses.reduce(
  (sum, c) => sum + c.data.youtubeLinks.length,
  0
);
const totalTutorials = allCourses.reduce(
  (sum, c) => sum + c.data.tutorials.length,
  0
);
---

<Layout
  title="Chen Quantum"
  description="Academic website of Chen Quantum — teaching assistant, researcher, educator, and co-founder of the TAU Quantum Community."
>
  <!-- ─── Hero ─────────────────────────────────────────────────── -->
  <section class="bg-white border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-20 pb-16 md:pt-28 md:pb-24">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-12 md:gap-16 items-center">

        <!-- Text block -->
        <div class="max-w-2xl">
          <!-- Status pill -->
          <div class="inline-flex items-center gap-2 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 flex-shrink-0"></span>
            <span class="text-xs font-medium text-slate-500 tracking-wide">
              M.Sc. Student &nbsp;·&nbsp; Teaching Assistant &nbsp;·&nbsp; Community Builder
            </span>
          </div>

          <!-- Name in display serif -->
          <h1
            class="font-display text-5xl md:text-6xl lg:text-7xl text-slate-900 leading-[1.05] tracking-tight mb-4"
          >
            Chen<br />Quantum.
          </h1>

          <!-- Hero theme -->
          <p class="text-base md:text-lg text-slate-700 font-medium tracking-tight mb-6 max-w-xl">
            Quantum Computing · Physics-Inspired ML · Mathematical Research Prototypes
          </p>

          <!-- Role / tagline -->
          <p class="text-lg md:text-xl text-slate-500 leading-relaxed mb-10 max-w-xl">
            I am an M.Sc. student exploring quantum computing, quantum machine
            learning, and physics-inspired algorithmic ideas through rigorous
            simulator-based prototypes, honest baselines, and reproducible code.
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-3">
            <a
              href="/projects"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
            >
              View Projects
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a
              href="/teaching"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-slate-600 text-sm font-semibold rounded-lg border border-slate-200 hover:border-slate-300 hover:text-slate-900 transition-colors"
            >
              Teaching Materials
            </a>
            <a
              href="/quantum-community"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-indigo-600 text-sm font-semibold rounded-lg border border-indigo-200 bg-indigo-50/40 hover:border-indigo-300 hover:bg-indigo-50 transition-colors"
            >
              Quantum Community
            </a>
            <a
              href="/files/cv/chen-gadi-cv-2026.pdf"
              download
              class="inline-flex items-center gap-2 px-5 py-2.5 text-slate-600 text-sm font-semibold rounded-lg border border-slate-200 hover:border-slate-300 hover:text-slate-900 transition-colors"
            >
              Download CV
            </a>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-slate-600 text-sm font-semibold rounded-lg border border-slate-200 hover:border-slate-300 hover:text-slate-900 transition-colors"
            >
              Contact
            </a>
          </div>
        </div>

        <!-- Logo -->
        <div class="hidden md:flex items-center justify-center">
          <div
            class="w-40 h-40 lg:w-48 lg:h-48 rounded-2xl border border-slate-200 bg-slate-50 flex items-center justify-center p-8"
          >
            <img
              src="/brand/logo.png"
              alt="Chen Quantum"
              class="w-full h-full object-contain"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Stats bar ──────────────────────────────────────────────── -->
  {
    allCourses.length > 0 && (
      <div class="border-b border-slate-100 bg-slate-50">
        <div class="mx-auto max-w-6xl px-6 py-4">
          <dl class="flex flex-wrap items-center gap-6 md:gap-8">
            <div class="flex items-baseline gap-1.5">
              <dt class="text-xs text-slate-400 order-2">courses taught</dt>
              <dd class="text-sm font-semibold text-slate-900 order-1 tabular-nums">
                {allCourses.length}
              </dd>
            </div>
            <span class="text-slate-200 hidden sm:inline" aria-hidden="true">|</span>
            <div class="flex items-baseline gap-1.5">
              <dt class="text-xs text-slate-400 order-2">lecture recordings</dt>
              <dd class="text-sm font-semibold text-slate-900 order-1 tabular-nums">
                {totalVideos}
              </dd>
            </div>
            <span class="text-slate-200 hidden sm:inline" aria-hidden="true">|</span>
            <div class="flex items-baseline gap-1.5">
              <dt class="text-xs text-slate-400 order-2">practice materials</dt>
              <dd class="text-sm font-semibold text-slate-900 order-1 tabular-nums">
                {totalTutorials + allMaterials.length}
              </dd>
            </div>
            <span class="text-slate-200 hidden sm:inline" aria-hidden="true">|</span>
            <div class="flex items-baseline gap-1.5">
              <dt class="text-xs text-slate-400 order-2">community events</dt>
              <dd class="text-sm font-semibold text-slate-900 order-1 tabular-nums">
                {allEvents.length}
              </dd>
            </div>
          </dl>
        </div>
      </div>
    )
  }

  <!-- ─── Teaching & Learning ────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-6 py-20 md:py-24">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">
          Teaching &amp; Learning
        </p>
        <h2 class="font-display text-3xl md:text-4xl text-slate-900">
          Mathematics for engineering students at TAU
        </h2>
      </div>
      <a
        href="/teaching"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors"
      >
        All teaching
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <a href="/teaching" class="group flex flex-col p-6 bg-white rounded-2xl border border-slate-200 hover:border-slate-300 hover:shadow-sm transition-all">
        <span class="text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full text-emerald-700 bg-emerald-50 border border-emerald-200 self-start mb-3">Active</span>
        <h3 class="text-base font-semibold text-slate-900 mb-2 group-hover:text-indigo-600 transition-colors">Linear Algebra</h3>
        <p class="text-sm text-slate-500 leading-relaxed mb-2 flex-1">
          Linear algebra for electrical and biomedical engineering. Systems,
          vector spaces, transformations, determinants, eigenvalues.
        </p>
        <p class="text-xs text-slate-400" dir="rtl">לינארית לחשמל · לינארית להנדסה ביו רפואית</p>
      </a>

      <a href="/teaching" class="group flex flex-col p-6 bg-white rounded-2xl border border-slate-200 hover:border-slate-300 hover:shadow-sm transition-all">
        <span class="text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full text-emerald-700 bg-emerald-50 border border-emerald-200 self-start mb-3">Active</span>
        <h3 class="text-base font-semibold text-slate-900 mb-2 group-hover:text-indigo-600 transition-colors">Calculus 2</h3>
        <p class="text-sm text-slate-500 leading-relaxed mb-2 flex-1">
          Sequences and series of functions, uniform convergence, Taylor and
          Fourier series, multivariable foundations, double integrals.
        </p>
        <p class="text-xs text-slate-400" dir="rtl">חדו״א 2</p>
      </a>

      <a href="/digital-courses" class="group flex flex-col p-6 bg-white rounded-2xl border border-slate-200 hover:border-slate-300 hover:shadow-sm transition-all">
        <span class="text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full text-amber-700 bg-amber-50 border border-amber-200 self-start mb-3">Coming soon</span>
        <h3 class="text-base font-semibold text-slate-900 mb-2 group-hover:text-indigo-600 transition-colors">Digital Courses</h3>
        <p class="text-sm text-slate-500 leading-relaxed flex-1">
          Structured online courses in physics, quantum theory, and quantum
          algorithms — Physics 1, Physics 2, Quantum 1, and Quantum Algorithms
          are in preparation for next year.
        </p>
      </a>
    </div>
  </section>

  <!-- ─── Quantum Community teaser ───────────────────────────────── -->
  <section class="border-t border-slate-100">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div class="rounded-2xl border border-indigo-100 bg-gradient-to-br from-indigo-50/60 to-slate-50 p-8 md:p-10">
        <p class="text-xs font-semibold text-indigo-600 uppercase tracking-widest mb-3">
          Community
        </p>
        <h2 class="font-display text-2xl md:text-3xl text-slate-900 mb-3 max-w-3xl">
          Quantum Technologies &amp; Science Community at Tel Aviv University
        </h2>
        <p class="text-base text-slate-600 leading-relaxed mb-6 max-w-3xl">
          A student-led community at Tel Aviv University that brings together
          students and researchers around invited talks, evenings on quantum
          computing and quantum technologies, and informal gatherings.
          Past events have hosted Prof. Yakir Aharonov, Prof. John M. Martinis,
          Prof. Emanuele Dalla Torre, Dr. Adi Pick, and others.
        </p>
        <a
          href="/quantum-community"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
        >
          See community events
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── Featured Courses ───────────────────────────────────────── -->
  {
    featuredCourses.length > 0 && (
      <section class="mx-auto max-w-6xl px-6 py-20 md:py-24">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">
              Teaching
            </p>
            <h2 class="font-display text-3xl md:text-4xl text-slate-900">
              Featured Courses
            </h2>
          </div>
          <a
            href="/courses"
            class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors"
          >
            All courses
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {featuredCourses.map((course) => (
            <CourseCard
              title={course.data.title}
              shortDescription={course.data.shortDescription}
              semester={course.data.semester}
              tags={course.data.tags}
              slug={course.id}
              featured={course.data.featured}
            />
          ))}
        </div>

        <div class="mt-8 sm:hidden">
          <a
            href="/courses"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
          >
            View all courses →
          </a>
        </div>
      </section>
    )
  }

  <!-- ─── Featured Materials ────────────────────────────────────── -->
  {
    featuredMaterials.length > 0 && (
      <section class="border-t border-slate-100">
        <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
          <div class="flex items-end justify-between mb-10">
            <div>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">
                Resources
              </p>
              <h2 class="font-display text-3xl md:text-4xl text-slate-900">
                Practice Materials
              </h2>
            </div>
            <a
              href="/materials"
              class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors"
            >
              All materials
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>

          <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {featuredMaterials.slice(0, 3).map((m) => (
              <MaterialCard
                title={m.data.title}
                description={m.data.description}
                subject={m.data.subject}
                type={m.data.type}
                tags={m.data.tags}
                slug={m.id}
                featured={m.data.featured}
                passwordProtected={m.data.passwordProtected}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ─── Site areas (Research, Projects, Library) ──────────────── -->
  <section class="border-t border-slate-100">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-12">
        Explore
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
        <!-- Research -->
        <div class="group">
          <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center mb-4 text-slate-500 group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="font-display text-xl text-slate-900 mb-3 group-hover:text-indigo-600 transition-colors">
            Research
          </h3>
          <p class="text-sm text-slate-500 leading-relaxed mb-4">
            Quantum algorithms and complexity theory, with a focus on
            mathematical foundations and practical implications.
          </p>
          <a
            href="/research"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-700 hover:text-indigo-600 transition-colors"
          >
            Explore research
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Projects -->
        <div class="group">
          <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center mb-4 text-slate-500 group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="font-display text-xl text-slate-900 mb-3 group-hover:text-indigo-600 transition-colors">
            Projects
          </h3>
          <p class="text-sm text-slate-500 leading-relaxed mb-4">
            Tools and experiments built alongside research and teaching —
            from quantum simulators to learning aids.
          </p>
          <a
            href="/projects"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-700 hover:text-indigo-600 transition-colors"
          >
            See projects
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Digital Courses -->
        <div class="group">
          <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center mb-4 text-slate-500 group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl text-slate-900 mb-3 group-hover:text-indigo-600 transition-colors">
            Digital Courses
          </h3>
          <p class="text-sm text-slate-500 leading-relaxed mb-4">
            Structured online courses in mathematics and quantum computing —
            currently in development.
          </p>
          <a
            href="/digital-courses"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-700 hover:text-indigo-600 transition-colors"
          >
            Learn more
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Quantum Community ──────────────────────────────────────── -->
  <section class="border-t border-slate-100 bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 text-white">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-white/10 border border-white/20">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
            <span class="text-xs font-semibold text-white/80 tracking-wide uppercase">
              Student Initiative
            </span>
          </div>
          <h2 class="font-display text-3xl md:text-4xl text-white mb-6 leading-tight">
            TAU Quantum Community
          </h2>
          <p class="text-base text-white/70 leading-relaxed mb-5">
            A student-led quantum computing community at Tel Aviv University —
            organising workshops, conferences, and lectures in collaboration
            with the TAU Quantum Information Center.
          </p>
          <p class="text-base text-white/70 leading-relaxed mb-8">
            Open to students, researchers, and anyone curious about quantum
            science and technology.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="/quantum-community"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-slate-900 text-sm font-semibold rounded-lg hover:bg-slate-100 transition-colors"
            >
              Explore the Community
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="/quantum-community/events"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-white text-sm font-semibold rounded-lg border border-white/30 hover:bg-white/10 transition-colors"
            >
              View Events
            </a>
          </div>
        </div>

        <!-- Community highlights -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { label: "Workshops & Events", icon: "🔬", value: `${allEvents.length}+` },
            { label: "Active Members", icon: "👥", value: "50+" },
            { label: "Partner Institutions", icon: "🏛️", value: "3" },
            {
              label: upcomingEvents.length > 0 ? "Next Event" : "Community Active",
              icon: "📅",
              value: upcomingEvents.length > 0 ? "Coming soon" : "Since 2025",
            },
          ].map(({ label, icon, value }) => (
            <div class="p-5 rounded-xl bg-white/10 border border-white/20">
              <p class="text-xl mb-2">{icon}</p>
              <p class="font-display text-2xl text-white mb-1">{value}</p>
              <p class="text-xs text-white/60">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CV / Contact CTA ──────────────────────────────────────── -->
  <section class="border-t border-slate-100">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- CV card -->
        <div class="p-8 rounded-2xl border border-slate-200 bg-slate-50 flex flex-col">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
            Academic Profile
          </p>
          <h3 class="font-display text-2xl text-slate-900 mb-3">
            Curriculum Vitae
          </h3>
          <p class="text-sm text-slate-500 leading-relaxed mb-6 flex-1">
            Full academic CV — education, teaching positions, research, and skills.
          </p>
          <div class="flex gap-3">
            <a

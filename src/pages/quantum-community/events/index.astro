---
import Layout from "../../../layouts/Layout.astro";
import EventCard from "../../../components/EventCard.astro";
import { getCollection } from "astro:content";

const allEvents = await getCollection("communityEvents", ({ data }) => !data.draft);
allEvents.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const upcoming = allEvents.filter((e) => e.data.status === "upcoming");
const past = allEvents.filter((e) => e.data.status === "past");
---

<Layout
  title="Community Events"
  description="Events organised by the TAU Quantum Community — workshops, conferences, lectures, and meetups."
>
  <!-- Page header -->
  <section class="border-b border-slate-100 bg-gradient-to-b from-slate-50 to-white">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-slate-500 mb-8">
        <a href="/" class="hover:text-slate-900 transition-colors">Home</a>
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <a href="/quantum-community" class="hover:text-slate-900 transition-colors">Quantum Community</a>
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-slate-700">Events</span>
      </nav>

      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        TAU Quantum Community
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5">
        Events
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed mb-8">
        Workshops, symposia, lectures, and community gatherings organised
        by and for the quantum student community.
      </p>

      {allEvents.length > 0 && (
        <dl class="flex flex-wrap gap-6">
          <div class="flex items-baseline gap-1.5">
            <dd class="text-sm font-semibold text-slate-900 tabular-nums">{upcoming.length}</dd>
            <dt class="text-xs text-slate-400">upcoming</dt>
          </div>
          <div class="flex items-baseline gap-1.5">
            <dd class="text-sm font-semibold text-slate-900 tabular-nums">{past.length}</dd>
            <dt class="text-xs text-slate-400">past events</dt>
          </div>
        </dl>
      )}
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-16">
    {allEvents.length === 0 ? (
      <div class="py-24 max-w-sm">
        <p class="font-display text-3xl text-slate-200 mb-4">No events yet.</p>
        <p class="text-sm text-slate-400 leading-relaxed">
          Upcoming events and past event details will appear here.
        </p>
      </div>
    ) : (
      <div class="space-y-14">
        {/* Upcoming */}
        {upcoming.length > 0 && (
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
              Upcoming
            </p>
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {upcoming.map((event) => (
                <EventCard
                  title={event.data.title}
                  description={event.data.description}
                  date={event.data.date}
                  eventType={event.data.eventType}
                  venue={event.data.venue}
                  status={event.data.status}
                  featured={event.data.featured}
                  slug={event.id}
                  collaborators={event.data.collaborators}
                  speakers={event.data.speakers}
                  registrationUrl={event.data.registrationUrl}
                />
              ))}
            </div>
          </div>
        )}

        {/* Past */}
        {past.length > 0 && (
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
              Past Events
            </p>
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {past.map((event) => (
                <EventCard
                  title={event.data.title}
                  description={event.data.description}
                  date={event.data.date}
                  eventType={event.data.eventType}
                  venue={event.data.venue}
                  status={event.data.status}
                  featured={event.data.featured}
                  slug={event.id}
                  collaborators={event.data.collaborators}
                  speakers={event.data.speakers}
                  registrationUrl={event.data.registrationUrl}
                />
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</Layout>

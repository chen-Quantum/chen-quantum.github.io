---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Digital Courses"
  description="Online and digital courses by Chen Quantum — coming soon."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Digital Learning
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5">
        Digital Courses
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed">
        Structured online courses in mathematics and quantum computing —
        currently in preparation.
      </p>
    </div>
  </section>

  <!-- Coming soon section -->
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">

    <!-- Status banner -->
    <div class="max-w-2xl mb-16">
      <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full bg-amber-50 border border-amber-200">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse flex-shrink-0"></span>
        <span class="text-xs font-semibold text-amber-700 tracking-wide">In Development</span>
      </div>
      <p class="text-lg text-slate-600 leading-relaxed">
        I am currently producing a set of comprehensive digital courses designed
        for students who want structured, self-paced learning materials in
        mathematics and quantum computing.
      </p>
    </div>

    <!-- Planned courses grid -->
    <div class="mb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
        Planned Courses
      </p>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: "Quantum Computing — From Zero to Algorithms",
            description: "A complete journey from linear algebra prerequisites through major quantum algorithms. Designed for CS and mathematics students with no prior quantum knowledge.",
            tags: ["Quantum Computing", "Algorithms"],
            status: "In Production",
          },
          {
            title: "Linear Algebra Masterclass",
            description: "Rigorous yet accessible coverage of linear algebra with geometric intuition, computational tools, and applications in data science and quantum mechanics.",
            tags: ["Linear Algebra", "Mathematics"],
            status: "Planned",
          },
          {
            title: "Mathematical Foundations of CS",
            description: "Logic, set theory, combinatorics, graph theory, and probability — the mathematical toolkit every serious computer scientist needs.",
            tags: ["Discrete Math", "Foundations"],
            status: "Planned",
          },
        ].map(({ title, description, tags, status }) => (
          <div class="flex flex-col p-6 bg-white rounded-xl border border-slate-200">
            <!-- Status pill -->
            <div class="flex items-center justify-between mb-4">
              <span
                class={`text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full ${
                  status === "In Production"
                    ? "text-amber-700 bg-amber-50 border border-amber-200"
                    : "text-slate-500 bg-slate-100"
                }`}
              >
                {status}
              </span>
            </div>

            <h3 class="text-base font-semibold text-slate-900 mb-3 leading-snug flex-none">
              {title}
            </h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-5 flex-1">
              {description}
            </p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {tags.map((tag) => (
                <span class="text-[0.65rem] font-medium text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full uppercase tracking-wide">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Notify CTA -->
    <div class="max-w-xl p-8 rounded-2xl bg-indigo-50 border border-indigo-100">
      <h2 class="font-display text-2xl text-slate-900 mb-3">
        Interested in early access?
      </h2>
      <p class="text-sm text-slate-600 leading-relaxed mb-6">
        Send me a message if you want to be notified when the first course
        launches, or if you have specific topics you want covered.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
      >
        Get in touch
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</Layout>

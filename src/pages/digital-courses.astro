---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Digital Courses"
  description="Online and digital courses by Chen Gadi — coming soon."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Digital Learning
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5">
        Digital Courses
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed">
        Structured digital courses in physics, quantum theory, and quantum
        algorithms are in preparation. Each course is being built around a
        clear topic list, recorded lectures, and accompanying notes.
      </p>
    </div>
  </section>

  <!-- Coming soon section -->
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">

    <!-- Status banner -->
    <div class="max-w-2xl mb-16">
      <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full bg-amber-50 border border-amber-200">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse flex-shrink-0"></span>
        <span class="text-xs font-semibold text-amber-700 tracking-wide">In Development</span>
      </div>
      <p class="text-lg text-slate-600 leading-relaxed">
        I am planning a set of digital courses designed for students who want
        structured, self-paced learning materials in mathematics and quantum
        computing. Nothing is available yet — this page previews what is planned.
      </p>
    </div>

    <!-- Planned courses grid -->
    <div class="mb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
        Planned Courses
      </p>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: "Physics 1",
            description: "Classical mechanics: kinematics, Newton's laws, energy and momentum, oscillations, and an introduction to waves.",
            topics: ["Mechanics", "Newton's laws", "Energy and momentum", "Oscillations", "Waves"],
            tags: ["Physics", "Mechanics"],
            status: "Coming next year",
          },
          {
            title: "Physics 2",
            description: "Electromagnetism: electrostatics, Gauss's law, electric potential, circuits, magnetostatics, Faraday induction, and the road to Maxwell's equations.",
            topics: ["Electrostatics", "Gauss's law", "Electric potential", "Circuits", "Magnetostatics", "Faraday induction", "Maxwell foundations"],
            tags: ["Physics", "Electromagnetism"],
            status: "Coming next year",
          },
          {
            title: "Quantum 1",
            description: "Introduction to quantum mechanics: wavefunctions, operators, measurement, spin, the Schrödinger equation, the harmonic oscillator, and angular momentum.",
            topics: ["Wavefunctions", "Operators", "Measurement", "Spin", "Schrödinger equation", "Harmonic oscillator", "Angular momentum"],
            tags: ["Quantum Mechanics", "Physics"],
            status: "Coming next year",
          },
          {
            title: "Quantum Algorithms",
            description: "Quantum computing from qubits to algorithms: gates and circuits, Deutsch–Jozsa, phase estimation, the Quantum Fourier Transform, Grover, Shor, variational algorithms, and quantum machine learning foundations.",
            topics: ["Qubits and gates", "Circuits", "Deutsch–Jozsa", "Phase estimation", "QFT", "Grover", "Shor foundations", "Variational algorithms", "QML foundations"],
            tags: ["Quantum Computing", "Algorithms"],
            status: "Coming next year",
          },
        ].map(({ title, description, topics, tags, status }) => (
          <div class="flex flex-col p-6 bg-white rounded-xl border border-slate-200">
            <!-- Status pill -->
            <div class="flex items-center justify-between mb-4">
              <span class="text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full text-amber-700 bg-amber-50 border border-amber-200">
                {status}
              </span>
            </div>

            <h3 class="text-base font-semibold text-slate-900 mb-3 leading-snug flex-none">
              {title}
            </h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-4 flex-1">
              {description}
            </p>

            <div class="mb-4">
              <p class="text-[0.6rem] font-semibold text-slate-400 uppercase tracking-wide mb-1.5">Topics</p>
              <ul class="text-xs text-slate-500 leading-relaxed space-y-0.5">
                {topics.slice(0, 5).map((t) => (<li>· {t}</li>))}
                {topics.length > 5 && <li class="text-slate-400">… and more</li>}
              </ul>
            </div>

            <div class="mb-4 grid grid-cols-2 gap-2 text-[0.65rem]">
              <span class="font-medium text-slate-500 bg-slate-100 px-2 py-1 rounded text-center">Materials: coming soon</span>
              <span class="font-medium text-slate-500 bg-slate-100 px-2 py-1 rounded text-center">Videos: coming soon</span>
            </div>

            <div class="flex flex-wrap gap-1.5 mt-auto">
              {tags.map((tag) => (
                <span class="text-[0.65rem] font-medium text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full uppercase tracking-wide">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Notify CTA -->
    <div class="max-w-xl p-8 rounded-2xl bg-indigo-50 border border-indigo-100">
      <h2 class="font-display text-2xl text-slate-900 mb-3">
        Interested in early access?
      </h2>
      <p class="text-sm text-slate-600 leading-relaxed mb-6">
        Send me a message if you want to be notified when the first course
        launches, or if you have specific topics you want covered.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
      >
        Get in touch
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</Layout>

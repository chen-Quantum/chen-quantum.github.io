---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects", ({ data }) => !data.draft);
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Projects" description="Tools and projects by Chen Gadi.">
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Work
      </p>
      <h1
        class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5"
      >
        Projects
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed">
        Tools, experiments, and side projects built alongside research and
        teaching.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-16">
    {
      projects.length === 0 ? (
        <div class="py-24 max-w-sm">
          <p class="font-display text-3xl text-slate-200 mb-4">
            Coming soon.
          </p>
          <p class="text-sm text-slate-400 leading-relaxed">
            Projects will be listed here as they are ready to share.
          </p>
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {projects.map((project) => (
            <div class="group flex flex-col bg-white rounded-xl border border-slate-200 hover:border-slate-300 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200 ease-out overflow-hidden">
              {project.data.thumbnail && (
                <div class="aspect-[16/9] bg-gradient-to-br from-slate-50 to-slate-100 border-b border-slate-100 flex items-center justify-center overflow-hidden">
                  <img
                    src={project.data.thumbnail}
                    alt={`${project.data.title} preview`}
                    loading="lazy"
                    class="w-full h-full object-contain p-2 group-hover:scale-[1.02] transition-transform duration-200 ease-out"
                  />
                </div>
              )}
              <div class="flex flex-col flex-1 p-6">
                {project.data.status && (
                  <span class="self-start text-[0.6rem] font-semibold uppercase tracking-wider text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full mb-3">
                    {project.data.status}
                  </span>
                )}
                <h3 class="text-base font-semibold text-slate-900 mb-2 group-hover:text-indigo-600 transition-colors">
                  {project.data.title}
                </h3>
                <p class="text-sm text-slate-500 mb-5 flex-1 leading-relaxed">
                  {project.data.description}
                </p>
                {project.data.tech.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mb-5">
                    {project.data.tech.map((t) => (
                      <span class="text-[0.65rem] font-semibold text-slate-500 bg-slate-100 uppercase tracking-wide px-2 py-0.5 rounded-full">
                        {t}
                      </span>
                    ))}
                  </div>
                )}
                <div class="flex items-center gap-4 mt-auto">
                  {project.data.github ? (
                    <a
                      href={project.data.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs font-semibold text-slate-600 hover:text-slate-900 transition-colors"
                    >
                      {project.data.repoLabel ?? "GitHub"} ↗
                    </a>
                  ) : project.data.repoNote ? (
                    <span class="text-xs font-medium text-slate-400 italic">
                      {project.data.repoNote}
                    </span>
                  ) : null}
                  {project.data.live && (
                    <a
                      href={project.data.live}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs font-semibold text-indigo-600 hover:text-indigo-700 transition-colors"
                    >
                      Live ↗
                    </a>
                  )}
                  {project.data.docs.map((d) => (
                    <a
                      href={d.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs font-semibold text-teal-700 hover:text-teal-800 transition-colors"
                    >
                      {d.label} ↗
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      )
    }
  </div>
</Layout>

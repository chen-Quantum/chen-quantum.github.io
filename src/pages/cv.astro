---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="CV"
  description="Curriculum Vitae of Chen Gadi — researcher, teaching assistant, and educator in mathematics and quantum computing."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Academic Profile
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5">
        Curriculum Vitae
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed mb-8">
        Full academic CV — education, teaching, research, and publications.
      </p>

      <!-- Action buttons -->
      <div class="flex flex-wrap gap-3">
        <a
          href="/files/cv/chen-gadi-cv-2026.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          View CV (PDF)
        </a>
        <a
          href="/files/cv/chen-gadi-cv-2026.pdf"
          download
          class="inline-flex items-center gap-2 px-5 py-2.5 text-slate-700 text-sm font-semibold rounded-lg border border-slate-200 hover:border-slate-300 hover:text-slate-900 transition-colors"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download CV
        </a>
      </div>
    </div>
  </section>

  <!-- CV summary sections -->
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-16 items-start">

      <!-- Left: CV highlights -->
      <div class="space-y-14">

        <!-- Education -->
        <section>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
            Education
          </p>
          <div class="relative">
            <div class="absolute left-[7px] top-2 bottom-2 w-px bg-slate-200" aria-hidden="true"></div>
            <div class="space-y-8 pl-6">
              {[
                {
                  degree: "M.Sc. in Particle Physics",
                  school: "Tel Aviv University",
                  period: "2024 — Present",
                  note: "Focus: quantum computing, quantum machine learning, and physics-inspired algorithms",
                  active: true,
                },
                {
                  degree: "B.Sc. in Mathematics and Physics",
                  school: "Tel Aviv University",
                  period: "2020 — 2024",
                  note: "Graduated with Honors (Magna Cum Laude) · Dean's List 2024",
                  active: false,
                },
              ].map(({ degree, school, period, note, active }) => (
                <div class="relative">
                  <div
                    class={`absolute -left-6 top-1.5 w-3.5 h-3.5 rounded-full border-2 flex items-center justify-center ${
                      active ? "border-indigo-500 bg-indigo-50" : "border-slate-300 bg-white"
                    }`}
                  >
                    {active && <div class="w-1.5 h-1.5 rounded-full bg-indigo-500" />}
                  </div>
                  <p class={`text-sm font-semibold mb-0.5 ${active ? "text-slate-900" : "text-slate-700"}`}>
                    {degree}
                  </p>
                  <p class="text-xs text-slate-500 mb-1">{school}</p>
                  <p class="text-xs text-slate-400">{period} &middot; {note}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <div class="border-t border-slate-100"></div>

        <!-- Teaching positions -->
        <section>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
            Teaching Experience
          </p>
          <div class="space-y-6">
            {[
              {
                role: "Teaching Assistant — Introduction to Quantum Computing",
                institution: "Tel Aviv University, Department of Computer Science",
                period: "Fall 2025",
                detail: "Weekly tutorials, practice materials, office hours, and grading.",
              },
              {
                role: "Teaching Assistant — Linear Algebra",
                institution: "Tel Aviv University, Department of Mathematics",
                period: "Spring 2026",
                detail: "Tutorial design, worksheets, and student mentoring.",
              },
              {
                role: "Teaching Assistant — Multivariable Calculus",
                institution: "Tel Aviv University, Department of Mathematics",
                period: "Fall 2025",
                detail: "Tutorial sessions and assignment design.",
              },
            ].map(({ role, institution, period, detail }) => (
              <div class="p-5 rounded-xl border border-slate-100 bg-slate-50/50">
                <p class="text-sm font-semibold text-slate-900 mb-1">{role}</p>
                <p class="text-xs text-slate-500 mb-1">{institution}</p>
                <p class="text-xs text-slate-400 mb-2">{period}</p>
                <p class="text-xs text-slate-500 leading-relaxed">{detail}</p>
              </div>
            ))}
          </div>
        </section>

        <div class="border-t border-slate-100"></div>

        <!-- Research interests -->
        <section>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
            Research Interests
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {[
              { area: "Quantum Algorithms", detail: "Complexity bounds, oracle separations, and circuit optimisation." },
              { area: "Linear Algebra Methods", detail: "Spectral methods in machine learning and network analysis." },
              { area: "Mathematical Foundations", detail: "Type theory, proof systems, and foundational CS." },
              { area: "Quantum Community", detail: "Building student communities around quantum science in Israel." },
            ].map(({ area, detail }) => (
              <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50">
                <p class="text-sm font-semibold text-slate-800 mb-1">{area}</p>
                <p class="text-xs text-slate-500 leading-relaxed">{detail}</p>
              </div>
            ))}
          </div>
        </section>

        <div class="border-t border-slate-100"></div>

        <!-- Skills -->
        <section>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
            Technical Skills
          </p>
          <div class="flex flex-wrap gap-2">
            {[
              "Python", "Qiskit", "NumPy", "LaTeX", "Mathematica",
              "Linear Algebra", "Quantum Circuits", "Complexity Theory",
              "Mathematical Writing", "Pedagogical Design",
            ].map((skill) => (
              <span class="text-xs font-medium text-slate-600 bg-slate-100 px-3 py-1.5 rounded-full">
                {skill}
              </span>
            ))}
          </div>
        </section>
      </div>

      <!-- Right sidebar -->
      <aside class="lg:sticky lg:top-20 space-y-4">
        <!-- Download card -->
        <div class="rounded-xl border border-indigo-100 bg-indigo-50 p-5">
          <p class="text-xs font-semibold text-indigo-400 uppercase tracking-widest mb-4">
            Full CV
          </p>
          <p class="text-sm text-slate-600 leading-relaxed mb-5">
            Download the complete curriculum vitae in PDF format.
          </p>
          <a
            href="/files/cv/chen-gadi-cv-2026.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 rounded-lg transition-colors mb-2"
          >
            View PDF
          </a>
          <a
            href="/files/cv/chen-gadi-cv-2026.pdf"
            download
            class="block w-full text-center text-sm font-medium text-slate-600 hover:text-slate-900 px-4 py-2.5 rounded-lg border border-slate-200 hover:border-slate-300 bg-white transition-colors"
          >
            Download
          </a>
        </div>

        <!-- Quick links -->
        <div class="rounded-xl border border-slate-100 bg-white p-5">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
            Explore
          </p>
          <ul class="flex flex-col gap-2" role="list">
            {[
              { href: "/research", label: "Research" },
              { href: "/courses", label: "Teaching" },
              { href: "/projects", label: "Projects" },
              { href: "/about", label: "About" },
              { href: "/contact", label: "Contact" },
            ].map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="flex items-center justify-between text-sm text-slate-600 hover:text-indigo-600 transition-colors py-0.5"
                >
                  {label}
                  <svg class="h-3 w-3 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const papers = await getCollection("research", ({ data }) => !data.draft);
papers.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Research"
  description="Research work and publications by Chen Quantum."
>
  <!-- Page header -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        Academic
      </p>
      <h1
        class="font-display text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-[1.05] tracking-tight mb-5"
      >
        Research
      </h1>
      <p class="text-base text-slate-500 max-w-xl leading-relaxed">
        Ongoing research interests, notes, and academic contributions.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-16">
    {
      papers.length === 0 ? (
        <div class="py-24 max-w-sm">
          <p class="font-display text-3xl text-slate-200 mb-4">
            Coming soon.
          </p>
          <p class="text-sm text-slate-400 leading-relaxed">
            Publications and research summaries will appear here as they are
            ready.
          </p>
        </div>
      ) : (
        <div class="space-y-4">
          {papers.map((paper) => (
            <div class="group p-6 bg-white rounded-xl border border-slate-200 hover:border-slate-300 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200 ease-out">
              <div class="flex items-start justify-between gap-6">
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-semibold text-slate-900 mb-2 leading-snug">
                    {paper.data.title}
                  </h3>
                  <p class="text-sm text-slate-500 leading-relaxed mb-3">
                    {paper.data.description}
                  </p>
                  <div class="flex flex-wrap items-center gap-2">
                    {paper.data.area && (
                      <span class="text-[0.65rem] font-semibold text-slate-500 bg-slate-100 uppercase tracking-wide px-2 py-0.5 rounded-full">
                        {paper.data.area}
                      </span>
                    )}
                    {paper.data.venue && (
                      <span class="text-xs text-slate-400 italic">
                        {paper.data.venue}
                      </span>
                    )}
                    {paper.data.coauthors.length > 0 && (
                      <span class="text-xs text-slate-400">
                        with {paper.data.coauthors.join(", ")}
                      </span>
                    )}
                  </div>
                </div>
                {paper.data.arxiv && (
                  <a
                    href={paper.data.arxiv}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-shrink-0 text-xs font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 px-3 py-1.5 rounded-lg transition-colors"
                  >
                    arXiv ↗
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      )
    }
  </div>
</Layout>

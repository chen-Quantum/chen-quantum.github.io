---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-100 mt-24">
  <div class="mx-auto max-w-6xl px-6 pt-12 pb-8">
    <!-- Four columns -->
    <div class="grid grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr] gap-10 mb-10">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-flex items-center gap-2.5 group mb-4">
          <div class="w-7 h-7 rounded-lg overflow-hidden border border-slate-100">
            <img
              src="/brand/logo.png"
              alt=""
              class="w-full h-full object-contain"
            />
          </div>
          <span
            class="font-semibold text-slate-700 text-sm group-hover:text-indigo-600 transition-colors"
          >
            Chen Quantum
          </span>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-64 mb-4">
          Teaching mathematics and quantum computing at the intersection of
          rigor and clarity.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-1.5 text-xs font-semibold text-indigo-600 hover:text-indigo-700 transition-colors"
        >
          Get in touch →
        </a>
      </div>

      <!-- Teaching -->
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
          Teaching
        </p>
        <ul class="flex flex-col gap-2.5" role="list">
          {
            [
              { href: "/courses", label: "Courses" },
              { href: "/materials", label: "Materials" },
              { href: "/digital-courses", label: "Digital Courses" },
              { href: "/contact", label: "Private Lessons" },
            ].map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-slate-500 hover:text-slate-900 transition-colors"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Academic -->
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
          Academic
        </p>
        <ul class="flex flex-col gap-2.5" role="list">
          {
            [
              { href: "/research", label: "Research" },
              { href: "/projects", label: "Projects" },
              { href: "/cv", label: "CV" },
              { href: "/about", label: "About" },
            ].map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-slate-500 hover:text-slate-900 transition-colors"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Community -->
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
          Community
        </p>
        <ul class="flex flex-col gap-2.5" role="list">
          {
            [
              { href: "/quantum-community", label: "Quantum Community" },
              { href: "/quantum-community/events", label: "Events" },
              { href: "/quantum-community/gallery", label: "Gallery" },
            ].map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-slate-500 hover:text-slate-900 transition-colors"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom rule -->
    <div class="pt-6 border-t border-slate-100 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-slate-400 order-2 sm:order-1">
        &copy; {year} Chen Quantum. All rights reserved.
      </p>
      <p class="text-xs text-slate-400 order-1 sm:order-2">
        Built with{" "}
        <a
          href="https://astro.build"
          class="hover:text-slate-600 transition-colors underline underline-offset-2"
          >Astro</a
        >{" "}
        &amp; Tailwind CSS
      </p>
    </div>
  </div>
</footer>

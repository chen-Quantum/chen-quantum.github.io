---
// Card for a tutorial/practice material in the materials listing.
interface Props {
  title: string;
  description: string;
  subject: string;
  type: string;
  tags: string[];
  slug: string;
  featured?: boolean;
  passwordProtected?: boolean;
}

const {
  title,
  description,
  subject,
  type,
  tags,
  slug,
  featured = false,
  passwordProtected = false,
} = Astro.props;

const typeColors: Record<string, string> = {
  tutorial: "text-indigo-600 bg-indigo-50 border-indigo-100",
  practice: "text-emerald-600 bg-emerald-50 border-emerald-100",
  worksheet: "text-amber-600 bg-amber-50 border-amber-100",
  notes: "text-sky-600 bg-sky-50 border-sky-100",
  "exam-prep": "text-rose-600 bg-rose-50 border-rose-100",
};

const badgeClass = typeColors[type] ?? "text-slate-600 bg-slate-50 border-slate-200";
---

<a
  href={`/materials/${slug}`}
  class="group flex flex-col p-6 bg-white rounded-xl border border-slate-200 hover:border-slate-300 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200 ease-out"
>
  <!-- Meta row -->
  <div class="flex items-center justify-between mb-4 gap-2">
    <span class={`text-[0.65rem] font-semibold uppercase tracking-wider border px-2.5 py-1 rounded-full ${badgeClass}`}>
      {type}
    </span>
    <div class="flex items-center gap-1.5">
      {passwordProtected && (
        <span title="Password protected" class="text-slate-300">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </span>
      )}
      {featured && (
        <span class="text-[0.65rem] font-semibold text-amber-600 uppercase tracking-wider">
          Featured
        </span>
      )}
    </div>
  </div>

  <!-- Subject -->
  <p class="text-xs font-medium text-slate-400 mb-2 uppercase tracking-wide">{subject}</p>

  <!-- Title -->
  <h3 class="text-base font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors leading-snug mb-3">
    {title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-slate-500 leading-relaxed flex-1 mb-5 line-clamp-3">
    {description}
  </p>

  <!-- Footer -->
  <div class="flex items-end justify-between gap-2 mt-auto">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 2).map((tag) => (
          <span class="text-[0.65rem] font-medium text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full tracking-wide uppercase">
            {tag}
          </span>
        ))}
      </div>
    )}
    <span class="flex-shrink-0 ml-auto text-slate-400 group-hover:text-indigo-600 group-hover:translate-x-0.5 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>

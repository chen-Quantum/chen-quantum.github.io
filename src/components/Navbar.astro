---
const navLinks = [
  { href: "/courses", label: "Courses" },
  { href: "/materials", label: "Materials" },
  { href: "/research", label: "Research" },
  { href: "/projects", label: "Projects" },
  {
    href: "/quantum-community",
    label: "Quantum Community",
    highlight: true,
  },
  { href: "/cv", label: "CV" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  pathname === href || (href !== "/" && pathname.startsWith(href));
---

<header class="sticky top-0 z-50 bg-white/96 backdrop-blur-md border-b border-slate-100">
  <nav
    class="mx-auto max-w-6xl px-6 flex items-center justify-between h-14"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2.5 group flex-shrink-0"
      aria-label="Chen Quantum home"
    >
      <div class="w-7 h-7 rounded-lg overflow-hidden border border-slate-100 flex-shrink-0">
        <img
          src="/brand/logo.png"
          alt=""
          class="w-full h-full object-contain"
          loading="eager"
        />
      </div>
      <span
        class="font-semibold text-slate-800 text-sm hidden sm:inline group-hover:text-indigo-600 transition-colors duration-200"
      >
        Chen Quantum
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-0.5" role="list">
      {
        navLinks.map(({ href, label, highlight }) => (
          <li>
            <a
              href={href}
              class={`px-3 py-1.5 rounded-md text-sm transition-colors duration-150 ${
                isActive(href)
                  ? "font-semibold text-slate-900 bg-slate-100"
                  : highlight
                    ? "font-medium text-indigo-600 hover:text-indigo-700 hover:bg-indigo-50"
                    : "font-medium text-slate-500 hover:text-slate-900 hover:bg-slate-50"
              }`}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      class="lg:hidden p-1.5 rounded-md text-slate-500 hover:text-slate-900 hover:bg-slate-50 transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.75"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"
        ></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="nav-menu" class="hidden lg:hidden border-t border-slate-100 bg-white">
    <ul class="mx-auto max-w-6xl px-4 py-2 flex flex-col" role="list">
      {
        navLinks.map(({ href, label, highlight }) => (
          <li>
            <a
              href={href}
              class={`block px-3 py-2.5 rounded-md text-sm transition-colors ${
                isActive(href)
                  ? "font-semibold text-slate-900 bg-slate-50"
                  : highlight
                    ? "font-medium text-indigo-600 hover:bg-indigo-50"
                    : "font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50"
              }`}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>

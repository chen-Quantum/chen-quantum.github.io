---
interface Props {
  title: string;
  shortDescription: string;
  semester: string;
  tags: string[];
  slug: string;
  featured?: boolean;
}

const {
  title,
  shortDescription,
  semester,
  tags,
  slug,
  featured = false,
} = Astro.props;
---

<a
  href={`/courses/${slug}`}
  class="group flex flex-col p-6 bg-white rounded-xl border border-slate-200 hover:border-slate-300 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200 ease-out"
>
  <!-- Meta row -->
  <div class="flex items-center justify-between mb-4">
    <span
      class="text-[0.7rem] font-semibold text-slate-400 uppercase tracking-widest"
    >
      {semester}
    </span>
    {
      featured && (
        <span class="text-[0.65rem] font-semibold text-indigo-600 uppercase tracking-wider">
          Featured
        </span>
      )
    }
  </div>

  <!-- Title -->
  <h3
    class="text-base font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors leading-snug mb-3"
  >
    {title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-slate-500 leading-relaxed flex-1 mb-5">
    {shortDescription}
  </p>

  <!-- Footer: tags + arrow -->
  <div class="flex items-end justify-between gap-2 mt-auto">
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.slice(0, 2).map((tag) => (
            <span class="text-[0.65rem] font-medium text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full tracking-wide uppercase">
              {tag}
            </span>
          ))}
        </div>
      )
    }
    <span
      class="flex-shrink-0 ml-auto text-slate-400 group-hover:text-indigo-600 group-hover:translate-x-0.5 transition-all"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M17 8l4 4m0 0l-4 4m4-4H3"
        ></path>
      </svg>
    </span>
  </div>
</a>

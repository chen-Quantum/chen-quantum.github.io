---
// Soft "course code" gate around opening / downloading a teaching PDF on this
// static GitHub Pages site.
//
// This is NOT security. The code lives in the page source and the PDF URL is
// public — anyone with devtools or the URL can still fetch it. This is a
// classroom-style download code that keeps the practice sheet from being
// casually opened by site visitors who arrive at the teaching page without
// taking the course. The inline PDF preview (PdfPreview.astro) stays visible
// without a code.
//
// Wording is deliberately modest: "Download code", "Preview is available
// without a code", and on a wrong code: "Incorrect code. The preview is still
// available." Do not describe this as secure / private / protected /
// encrypted / DRM.
interface Props {
  pdfPath: string;
  code: string;
  label?: string;
  variant?: "primary" | "fallback";
}
const {
  pdfPath,
  code,
  label = "Open / download PDF",
  variant = "primary",
} = Astro.props;

const summaryClass =
  variant === "primary"
    ? "inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-indigo-700 bg-indigo-50 border border-indigo-100 rounded-lg hover:bg-indigo-100 cursor-pointer select-none transition-colors"
    : "inline-flex items-center gap-1.5 text-xs font-semibold text-indigo-700 hover:text-indigo-900 cursor-pointer select-none";
---

<details class="pdf-gate" data-pdf-path={pdfPath} data-pdf-code={code}>
  <summary class={summaryClass}>
    <svg
      class="w-4 h-4"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
      ></path>
    </svg>
    <span>{label}</span>
  </summary>

  <form class="pdf-gate-form mt-3 p-3 border border-slate-200 rounded-lg bg-white max-w-sm">
    <label class="block">
      <span class="block text-xs font-semibold text-slate-500 mb-1.5">
        Download code
      </span>
      <input
        type="text"
        autocomplete="off"
        spellcheck="false"
        class="pdf-gate-input w-full px-3 py-1.5 text-sm border border-slate-200 rounded-md focus:outline-none focus:border-indigo-300"
        placeholder="Enter the course code"
      />
    </label>
    <div class="mt-2 flex items-center gap-3 flex-wrap">
      <button
        type="submit"
        class="inline-flex items-center px-3 py-1.5 text-sm font-semibold text-white bg-indigo-600 rounded-md hover:bg-indigo-700 transition-colors"
      >
        Open PDF
      </button>
      <p class="pdf-gate-msg text-xs text-slate-500" aria-live="polite">
        Preview is available without a code.
      </p>
    </div>
  </form>
</details>

<style>
  .pdf-gate > summary {
    list-style: none;
  }
  .pdf-gate > summary::-webkit-details-marker {
    display: none;
  }
</style>

<script is:inline>
  // One delegated handler for every .pdf-gate on the page. Soft / classroom
  // gate — the code is in the page source, so this is not security. It only
  // prevents casual one-click downloads.
  (function () {
    if (window.__pdfGateBound) return;
    window.__pdfGateBound = true;
    document.addEventListener("submit", function (e) {
      var form =
        e.target && e.target.closest && e.target.closest(".pdf-gate-form");
      if (!form) return;
      e.preventDefault();
      var root = form.closest(".pdf-gate");
      if (!root) return;
      var input = root.querySelector(".pdf-gate-input");
      var msg = root.querySelector(".pdf-gate-msg");
      if (!input || !msg) return;
      var code = root.getAttribute("data-pdf-code") || "";
      var pdf = root.getAttribute("data-pdf-path") || "";
      if (input.value === code) {
        msg.textContent = "Opening…";
        msg.classList.remove("text-rose-600");
        msg.classList.add("text-emerald-600");
        window.open(pdf, "_blank", "noopener,noreferrer");
      } else {
        msg.textContent = "Incorrect code. The preview is still available.";
        msg.classList.remove("text-emerald-600");
        msg.classList.add("text-rose-600");
        input.focus();
        input.select();
      }
    });
  })();
</script>

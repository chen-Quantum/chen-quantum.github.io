---
interface Props {
  label?: string;    // small uppercase label above title
  title: string;
  description?: string;
  align?: "left" | "center";
  viewAllHref?: string;
  viewAllLabel?: string;
}

const {
  label,
  title,
  description,
  align = "left",
  viewAllHref,
  viewAllLabel = "View all",
} = Astro.props;

const isCenter = align === "center";
---

<div class={`mb-10 ${isCenter ? "text-center" : ""}`}>
  <div class={`flex items-end ${isCenter ? "justify-center" : "justify-between"} gap-4`}>
    <div>
      {label && (
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">
          {label}
        </p>
      )}
      <h2
        class={`font-display text-3xl md:text-4xl text-slate-900 leading-tight ${isCenter ? "" : ""}`}
      >
        {title}
      </h2>
    </div>
    {viewAllHref && !isCenter && (
      <a
        href={viewAllHref}
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors flex-shrink-0"
      >
        {viewAllLabel}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-3.5 w-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    )}
  </div>
  {description && (
    <p class={`mt-4 text-base text-slate-500 leading-relaxed max-w-2xl ${isCenter ? "mx-auto" : ""}`}>
      {description}
    </p>
  )}
  {viewAllHref && isCenter && (
    <a
      href={viewAllHref}
      class="inline-flex items-center gap-1.5 mt-6 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors"
    >
      {viewAllLabel}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-3.5 w-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  )}
</div>

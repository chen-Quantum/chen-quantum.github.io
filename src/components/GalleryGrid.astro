---
// Reusable photo gallery grid.
// photos: array of { file: string, caption?: string }
// file paths are relative to /public/community/gallery/
interface PhotoItem {
  file: string;
  caption?: string;
}

interface Props {
  photos: PhotoItem[];
  basePath?: string;  // base URL path, default "/community/gallery/"
  columns?: 2 | 3 | 4;
}

const { photos, basePath = "/community/gallery/", columns = 3 } = Astro.props;

const colClass: Record<number, string> = {
  2: "sm:grid-cols-2",
  3: "sm:grid-cols-2 lg:grid-cols-3",
  4: "sm:grid-cols-2 lg:grid-cols-4",
};
---

{photos.length === 0 ? (
  <div class="py-16 text-center rounded-xl border border-dashed border-slate-200 bg-slate-50">
    <svg class="mx-auto h-10 w-10 text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    <p class="text-sm text-slate-400">Photos coming soon</p>
    <p class="text-xs text-slate-300 mt-1">Place images in <code class="text-slate-400">public/community/gallery/</code> and update the content file.</p>
  </div>
) : (
  <div class={`grid grid-cols-1 ${colClass[columns] ?? colClass[3]} gap-3`}>
    {photos.map((photo) => (
      <figure class="group relative overflow-hidden rounded-xl bg-slate-100 aspect-[4/3]">
        <img
          src={`${basePath}${photo.file}`}
          alt={photo.caption ?? ""}
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
        {photo.caption && (
          <figcaption class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/60 to-transparent px-3 pb-3 pt-8 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <p class="text-xs font-medium text-white leading-snug">{photo.caption}</p>
          </figcaption>
        )}
      </figure>
    ))}
  </div>
)}

---
// Simple, honest inline PDF preview for teaching practice sheets.
//
// Collapsed by default; clicking "Preview sheet" expands a browser-native PDF
// view (iframe) with an always-available "Open PDF" fallback link. This is NOT
// the deterrence viewer (src/components/PdfViewer.astro) — these sheets are
// meant to be read and downloaded freely by students, so there is no watermark,
// no right-click block, and no hidden download. No heavy PDF.js dependency.
//
// Responsive: some mobile browsers do not render PDFs inline in an iframe, so
// the "Open PDF" link is always shown as a reliable fallback.
import PdfDownloadGate from "./PdfDownloadGate.astro";
interface Props {
  pdfPath: string; // e.g. "/files/teaching/calculus-2/tirgul1.pdf"
  title: string; // human label for aria/title, e.g. the tutorial title
  defaultOpen?: boolean; // expand the <details> by default (off everywhere today)
  downloadCode?: string; // if set, the "Open PDF" fallback becomes a code-gated download
  hidePdfToolbar?: boolean; // when true, append #toolbar=0&navpanes=0&scrollbar=0 to the iframe src
}
const {
  pdfPath,
  title,
  defaultOpen = false,
  downloadCode,
  hidePdfToolbar = true,
} = Astro.props;

// PDF URL fragment for the iframe preview ONLY. The full-PDF open/download
// path (PdfDownloadGate, target=_blank) uses the raw pdfPath without this
// fragment, so the gated download works normally. The fragment is advisory:
// Chromium-family browsers honour #toolbar=0&navpanes=0&scrollbar=0; Firefox
// and Safari may render the PDF with their own viewer chrome regardless.
const previewFragment = hidePdfToolbar
  ? "#toolbar=0&navpanes=0&scrollbar=0&view=FitH"
  : "#view=FitH";
---

<details class="pdf-preview group mt-1" open={defaultOpen}>
  <summary
    class="inline-flex items-center gap-2 cursor-pointer select-none text-sm font-semibold text-slate-600 hover:text-indigo-700 transition-colors"
  >
    <svg
      class="w-4 h-4 transition-transform group-open:rotate-90"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
    <span class="group-open:hidden">Preview sheet</span>
    <span class="hidden group-open:inline">Hide preview</span>
  </summary>

  <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50 overflow-hidden">
    <iframe
      src={`${pdfPath}${previewFragment}`}
      title={`Preview: ${title}`}
      loading="lazy"
      class="w-full h-[60vh] min-h-[360px] max-h-[760px] border-0 bg-white"
    ></iframe>
    <div
      class="flex items-center justify-between gap-3 px-4 py-2.5 border-t border-slate-200 bg-white"
    >
      <p class="text-xs text-slate-400 leading-snug">
        Preview not loading? Some mobile browsers don't render PDFs inline.
      </p>
      {downloadCode ? (
        <PdfDownloadGate
          pdfPath={pdfPath}
          code={downloadCode}
          variant="fallback"
          label="Open PDF"
        />
      ) : (
        <a
          href={pdfPath}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-xs font-semibold text-indigo-700 hover:text-indigo-900 whitespace-nowrap"
        >
          Open PDF
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </div>
  </div>
</details>

<style>
  /* Use our own chevron instead of the default disclosure triangle. */
  .pdf-preview > summary {
    list-style: none;
  }
  .pdf-preview > summary::-webkit-details-marker {
    display: none;
  }
</style>
